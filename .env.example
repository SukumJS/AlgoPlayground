# ===========================================
# AlgoPlayground Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Database URL (for Prisma)
# Get this from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/database
# Use the "Connection string" under "Connection pooling" section
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://postgres:password@localhost:5432/algoplayground

# Direct connection URL (for migrations)
# Use the "Direct connection" string
DIRECT_URL=postgresql://postgres:password@localhost:5432/algoplayground

# ===========================================
# Setup Instructions
# ===========================================
# 
# 1. Create a Supabase project at https://supabase.com
# 
# 2. Get your API keys:
#    - Go to Project Settings > API
#    - Copy "Project URL" to NEXT_PUBLIC_SUPABASE_URL
#    - Copy "anon public" key to NEXT_PUBLIC_SUPABASE_ANON_KEY
# 
# 3. Get your database connection strings:
#    - Go to Project Settings > Database
#    - Under "Connection string", select "URI"
#    - Copy the pooler connection string to DATABASE_URL
#    - Copy the direct connection string to DIRECT_URL
# 
# 4. Set up Google OAuth in Supabase:
#    - Go to Authentication > Providers > Google
#    - Enable Google provider
#    - Add your Google OAuth credentials
#    - Add authorized redirect URL to Google Console
#
# 5. Run database migrations:
#    npm run db:push
#
# 6. (Optional) Seed the database:
#    npm run db:seed
