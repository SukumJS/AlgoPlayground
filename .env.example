# ===========================================
# AlgoPlayground Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values

# Firebase Configuration (Client-side)
# Get these from: Firebase Console > Project Settings > General > Your apps > Web app
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Firebase Admin SDK (Server-side)
# Get this from: Firebase Console > Project Settings > Service accounts > Generate new private key
# Copy the entire JSON content and paste it as a single line (escaped)
# Example: {"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",...}
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project-id",...}

# ===========================================
# Setup Instructions
# ===========================================
# 
# 1. Create a Firebase project at https://console.firebase.google.com
# 
# 2. Set up Firebase Authentication:
#    - Go to Authentication > Sign-in method
#    - Enable Google as a sign-in provider
#    - Add your authorized domains
# 
# 3. Set up Firestore Database:
#    - Go to Firestore Database
#    - Create database (start in production mode)
#    - Choose a location closest to your users
# 
# 4. Get your Firebase config:
#    - Go to Project Settings > General
#    - Scroll to "Your apps" section
#    - If no web app exists, click "Add app" > Web
#    - Copy the firebaseConfig values to the NEXT_PUBLIC_* variables above
# 
# 5. Generate a service account key:
#    - Go to Project Settings > Service accounts
#    - Click "Generate new private key"
#    - Download the JSON file
#    - Copy the entire JSON content (as a single line) to FIREBASE_SERVICE_ACCOUNT_KEY
#    - IMPORTANT: Keep this key secure and never commit it to version control!
# 
# 6. Set up Firestore Security Rules:
#    Go to Firestore > Rules and add:
#    
#    rules_version = '2';
#    service cloud.firestore {
#      match /databases/{database}/documents {
#        // Users can only read/write their own data
#        match /users/{userId} {
#          allow read, write: if request.auth != null && request.auth.uid == userId;
#          
#          match /{subcollection}/{document=**} {
#            allow read, write: if request.auth != null && request.auth.uid == userId;
#          }
#        }
#        
#        // Health check collection (read-only)
#        match /_health/{document=**} {
#          allow read: if request.auth != null;
#        }
#      }
#    }
#
# 7. Run the development server:
#    npm run dev
